<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.board.mapper.MemberMapper">

    <insert id="save" parameterType="com.example.board.dto.MemberDTO">
        INSERT INTO members (user_id, password, user_name, email, created_at)
        VALUES (#{userId}, #{password}, #{userName}, #{email}, NOW())
    </insert>

    <select id="findByUserId" parameterType="String" resultType="com.example.board.dto.MemberDTO">
        SELECT * FROM members WHERE user_id = #{userId}
    </select>

	<select id="checkExistID" parameterType="String" resultType="com.example.board.dto.MemberDTO">
		SELECT * FROM members WHERE user_id = #{userId}
	</select>

	<select id= "checkExistEmail" parameterType="String" resultType="com.example.board.dto.MemberDTO">
		SELECT * FROM members WHERE email = #{email}
	</select>
	<select id= "findId" parameterType="com.example.board.dto.MemberDTO" resultType="com.example.board.dto.MemberDTO">
		SELECT * FROM members
		WHERE user_name = #{userName} AND email = #{email}
	</select>
		<select id= "checkMember" parameterType="com.example.board.dto.MemberDTO" resultType="com.example.board.dto.MemberDTO">
		SELECT * FROM members
		WHERE user_id = #{userId} AND user_name = #{userName} AND email = #{email}
	</select>
		<update id= "updatePassword" parameterType="com.example.board.dto.MemberDTO" >
		UPDATE members
		SET password = #{password}
		WHERE user_id = #{userId}
	</update>

</mapper>

